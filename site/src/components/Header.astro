---
import { Image } from "astro:assets";
import logoBlack from "../assets/logo-black.png";
import { whatsappLink } from "../data/site";

const nav = [
  { href: "/catalogo", label: "Catálogo" },
  { href: "/servicos", label: "Serviços" },
  { href: "/sobre", label: "Sobre" },
  { href: "/contato", label: "Contato" },
];

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-white/80 backdrop-blur border-b border-[var(--color-line)]">
  <div class="mx-auto max-w-6xl px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label="JB Luthier — Início">
      <Image src={logoBlack} alt="JB Luthier" width={48} height={48} class="h-12 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-10">
      {
        nav.map((item) => {
          const active = pathname === item.href || pathname.startsWith(item.href + "/");
          return (
            <a
              href={item.href}
              class:list={[
                "text-sm tracking-wide uppercase transition-colors",
                active ? "text-[var(--color-ink)]" : "text-[var(--color-muted)] hover:text-[var(--color-ink)]",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <a
      href={whatsappLink()}
      target="_blank"
      rel="noopener"
      class="hidden md:inline-flex items-center gap-2 text-sm font-medium border border-[var(--color-ink)] px-4 py-2 hover:bg-[var(--color-ink)] hover:text-white transition-colors"
    >
      WhatsApp
    </a>

    <button
      id="menu-toggle"
      class="md:hidden inline-flex items-center justify-center p-2"
      aria-label="Abrir menu"
      aria-expanded="false"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-[var(--color-line)]">
    <nav class="mx-auto max-w-6xl px-6 py-6 flex flex-col gap-5">
      {
        nav.map((item) => (
          <a href={item.href} class="text-base uppercase tracking-wide">
            {item.label}
          </a>
        ))
      }
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener"
        class="mt-2 inline-flex items-center gap-2 text-sm font-medium border border-[var(--color-ink)] px-4 py-2 w-fit"
      >
        WhatsApp
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
