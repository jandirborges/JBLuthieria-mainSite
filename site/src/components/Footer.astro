---
import { Image } from "astro:assets";
import logoWhite from "../assets/logo-white.png";
import { site, whatsappLink } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-ink)] text-white mt-32">
  <div class="mx-auto max-w-6xl px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
    <div>
      <Image src={logoWhite} alt="JB Luthier" width={64} height={64} class="h-16 w-auto" />
      <p class="mt-6 text-sm text-white/70 max-w-xs leading-relaxed">
        Violões artesanais feitos peça por peça, e luthieria especializada em
        instrumentos de corda.
      </p>
    </div>

    <div>
      <h3 class="text-xs uppercase tracking-widest text-white/50 mb-4">Navegação</h3>
      <ul class="space-y-3 text-sm">
        <li><a href="/catalogo" class="hover:text-white/70">Catálogo</a></li>
        <li><a href="/servicos" class="hover:text-white/70">Serviços</a></li>
        <li><a href="/sobre" class="hover:text-white/70">Sobre</a></li>
        <li><a href="/contato" class="hover:text-white/70">Contato</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-xs uppercase tracking-widest text-white/50 mb-4">Contato</h3>
      <ul class="space-y-3 text-sm text-white/80">
        <li>
          <a href={whatsappLink()} target="_blank" rel="noopener" class="hover:text-white">
            WhatsApp {site.whatsapp.display}
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`} class="hover:text-white">
            {site.email}
          </a>
        </li>
        <li>
          <a href={site.instagram} target="_blank" rel="noopener" class="hover:text-white">
            Instagram
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-6xl px-6 py-6 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-white/50">
      <p>© {year} JB Luthier. Todos os direitos reservados.</p>
      <p>Jandir Borges Luthieria</p>
    </div>
  </div>
</footer>
