---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contato — JB Luthier" description="Entre em contato com o luthier Jandir Borges.">
  <section class="mx-auto max-w-6xl px-6 pt-24 pb-32 grid grid-cols-1 md:grid-cols-2 gap-16">
    <div>
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-muted)] mb-6">Contato</p>
      <h1 class="font-serif text-5xl md:text-6xl tracking-tight">
        Vamos conversar.
      </h1>
      <p class="mt-6 text-[var(--color-muted)] leading-relaxed">
        O atendimento é direto com o luthier. O caminho mais rápido é o
        WhatsApp — respostas geralmente no mesmo dia.
      </p>

      <div class="mt-12 space-y-6">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-muted)] mb-2">WhatsApp</p>
          <a
            href="https://wa.me/5500000000000"
            target="_blank"
            rel="noopener"
            class="font-serif text-2xl underline underline-offset-4 hover:text-[var(--color-muted)]"
          >
            (00) 00000-0000
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-muted)] mb-2">E-mail</p>
          <a
            href="mailto:contato@jbluthieria.com"
            class="font-serif text-2xl underline underline-offset-4 hover:text-[var(--color-muted)]"
          >
            contato@jbluthieria.com
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-muted)] mb-2">Oficina</p>
          <p class="font-serif text-2xl">Endereço em breve</p>
        </div>
      </div>
    </div>

    <form class="bg-[var(--color-subtle)] p-8 md:p-10 space-y-6" method="POST" action="#">
      <div>
        <label for="nome" class="block text-xs uppercase tracking-[0.2em] mb-2">Nome</label>
        <input
          id="nome"
          name="nome"
          type="text"
          required
          class="w-full bg-transparent border-b border-[var(--color-line)] py-3 focus:outline-none focus:border-[var(--color-ink)]"
        />
      </div>
      <div>
        <label for="email" class="block text-xs uppercase tracking-[0.2em] mb-2">E-mail</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full bg-transparent border-b border-[var(--color-line)] py-3 focus:outline-none focus:border-[var(--color-ink)]"
        />
      </div>
      <div>
        <label for="mensagem" class="block text-xs uppercase tracking-[0.2em] mb-2">Mensagem</label>
        <textarea
          id="mensagem"
          name="mensagem"
          rows="5"
          required
          class="w-full bg-transparent border-b border-[var(--color-line)] py-3 resize-none focus:outline-none focus:border-[var(--color-ink)]"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full bg-[var(--color-ink)] text-white py-4 text-sm uppercase tracking-wide hover:bg-black/80 transition-colors"
      >
        Enviar
      </button>
      <p class="text-xs text-[var(--color-muted)]">
        Formulário será conectado ao Formspree na etapa de polimento.
      </p>
    </form>
  </section>
</Layout>
